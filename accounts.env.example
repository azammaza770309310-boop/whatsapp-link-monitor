# Telegram API credentials (from https://my.telegram.org)
API_ID=YOUR_API_ID_HERE
API_HASH=YOUR_API_HASH_HERE

# User account (for monitoring)
PHONE=+YOUR_PHONE_NUMBER

# Bot token (from @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Destination channel ID (starts with -100)
# Run setup_v6.py locally to discover this
CHANNEL_ID=-100XXXXXXXXXX

# Owner ID (optional - restricts commands to specific user)
# Get your ID from @userinfobot
OWNER_ID=

# Logging
LOG_LEVEL=INFO

# Expired Link Checking
CHECK_EXPIRED=true
HTTP_TIMEOUT=6

# History Scan Settings
HISTORY_MAX_PER_CHAT=500
HISTORY_BATCH_SIZE=5
HISTORY_SKIP_CHANNEL_POSTS=false

# Startup scan (None/7/30/60/90)
STARTUP_SCAN_DAYS=None

# String Session (REQUIRED for cloud deployment - Render/Railway)
# Get this by running export_session.py locally
USER_SESSION_STRING=

# Proxy (optional - for blocked networks)
# Format: socks5:host:port or http:host:port
PROXY=
